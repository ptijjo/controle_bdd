# Copier ce fichier vers `.env` et renseigner les valeurs.

# Environnement (development | production | test)
NODE_ENV=development

# Base de données (SQLite local ou PostgreSQL)
DATABASE_URL="file:./prisma/db.sqlite"

# Serveur HTTP
PORT=8585

# CORS (front-end)
ORIGIN=http://localhost:3000
CREDENTIALS=true

# JWT — access (Bearer) et refresh (cookie httpOnly sur /auth)
ACCESS_TOKEN_SECRET=change-me-access
ACCESS_TOKEN_EXPIRES_SEC=86400
REFRESH_TOKEN_SECRET=change-me-refresh
REFRESH_TOKEN_EXPIRES_SEC=604800

# Invitations (inscription par lien)
SECRET_KEY_INVITATION=change-me-invitation
INVITATION_TOKEN_EXPIRES_SEC=86400
FRONT_END=http://localhost:3000/enregistrement

# Rate limiting global (ThrottlerGuard)
THROTTLE_LIMIT=10
THROTTLE_TTL_MS=60000

# Verrouillage après échecs de connexion
LOGIN_IP_FAIL_BEFORE_BLOCK=3
LOGIN_IP_BLOCK_MINUTES=30
LOGIN_FAIL_BEFORE_ACCOUNT_LOCK=3
LOGIN_ACCOUNT_LOCK_MINUTES=30

# Alias historiques (.env legacy — préférer LOGIN_* ci-dessus)
NUMBER_OF_FAIL_BEFORE_LOCK=3
TIME_LOCK=30

# Bcrypt
SALT_ROUNDS=14

# Mailjet
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=
EMAIL=noreply@example.com

# Destinataires métier (PDF formulaire, etc.)
Marin=chef-secteur@example.com
Alexander=
Sebastien=
Carine=

# Compte initial (seeder au démarrage si l’e-mail n’existe pas)
EMAIL_SEEDER=admin@example.com
PASSWORD_SEEDER=ChangeMeSecurePassword!
